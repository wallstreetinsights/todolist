# Copy to .env for local development against Railway Postgres.
# In Railway dashboard: Postgres service -> Variables -> DATABASE_URL

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@switchyard.proxy.rlwy.net:34410/railway?sslmode=require

# Optional when using separate PG* variables instead of DATABASE_URL
# PGHOST=switchyard.proxy.rlwy.net
# PGPORT=34410
# PGUSER=postgres
# PGPASSWORD=YOUR_PASSWORD
# PGDATABASE=railway

CORS_ORIGINS=http://localhost:5173
