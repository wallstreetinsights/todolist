# Local development against Railway Postgres (use DATABASE_PUBLIC_URL, not internal URL).
# Railway deployment: reference Postgres DATABASE_URL in Backend service variables.

# Public proxy URL for local machine (from Postgres -> Variables -> DATABASE_PUBLIC_URL)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@switchyard.proxy.rlwy.net:34410/railway?sslmode=require

# Railway internal URL (only works inside Railway, do NOT use locally):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres.railway.internal:5432/railway

CORS_ORIGINS=http://localhost:5173
